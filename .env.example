# --- Frontend (must be prefixed with VITE_) ---
# Remote Supabase project – leave empty to run without backend (localStorage fallback).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase edge function secrets (server-side only) ---
# Used by supabase/functions/* and supabase start --env-file .env
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: override default model providers
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
